end

analysis SimpleRLCTransient
  extends TransientAnalysis(alg = ODEAlg.Rodas5P(), abstol = 10m, reltol = 1m, start = 0, stop = 10, verbose = DEVerbosity.Detailed(), log_file = "sRLC.log")
  model::RLCModel() = RLCModel()
relations
end