"""
Series RLC circuit driven by a sinusoidal voltage input.

This component models a series RLC circuit. It consists of a resistor (R),
an inductor (L), and a capacitor (C) connected in series with an ideal
voltage source. The voltage provided by the source is a sinusoidal waveform
generated by a Sine block. A ground component provides the reference potential.
Initial conditions for the inductor current ($i_L(0)$) and capacitor voltage ($v_C(0)$)
are specified directly in the `relations` section of the component model.
"""
example component SinRLC
  "Resistor element with a resistance of 100 Ohms."
  resistor = ElectricalComponents.Analog.Basic.Resistor(R = 100) {^resistor}
  "Capacitor element with a capacitance of 1 milliFarad."
  capacitor = ElectricalComponents.Analog.Basic.Capacitor(C = 1m) {^capacitor}
  "Inductor element with an inductance of 1 Henry."
  inductor = ElectricalComponents.Analog.Basic.Inductor(L = 1) {^inductor}
  "Ideal voltage source whose output voltage is externally defined."
  source = ElectricalComponents.Analog.Sources.VoltageSource() {^source}
  "Sine wave generator block with configured frequency (1 Hz), amplitude (1 unit), and phase (0 rad)."
  sine = BlockComponents.Sources.Sine(frequency = 1, amplitude = 1, phase = 0) {^sine}
  "Ground connection providing the zero-potential reference."
  ground = ElectricalComponents.Analog.Basic.Ground() {^ground}
relations
  initial inductor.i = 0
  initial capacitor.v = 10
  connect(sine.y, source.V) {^id7}
  connect(source.n, inductor.p) {^id8}
  connect(inductor.n, resistor.n, capacitor.n) {^id9}
  connect(resistor.p, ground.g, capacitor.p, source.p) {^id10}
metadata {
  "Dyad": {
    "icons": {"default": "dyad://ElectricalComponents/Example.svg"},
    "tests": {
      "case1": {
        "stop": 10,
        "expect": {"initial": {"capacitor.v": 10}, "final": {"capacitor.v": -0.06781383813851176}}
      }
    }
  },
  "_links": {
    "resistor": {
      "Dyad": {
        "placement": {"icon": {"x1": 550, "y1": 200, "x2": 650, "y2": 300, "rot": -90}}
      }
    },
    "capacitor": {
      "Dyad": {
        "placement": {"icon": {"x1": 400, "y1": 200, "x2": 500, "y2": 300, "rot": -90}}
      }
    },
    "inductor": {"Dyad": {"placement": {"icon": {"x1": 300, "y1": 50, "x2": 400, "y2": 150}}}},
    "source": {
      "Dyad": {
        "placement": {"icon": {"x1": 200, "y1": 200, "x2": 300, "y2": 300, "rot": -90}}
      }
    },
    "sine": {"Dyad": {"placement": {"icon": {"x1": 50, "y1": 200, "x2": 150, "y2": 300}}}},
    "ground": {"Dyad": {"placement": {"icon": {"x1": 400, "y1": 450, "x2": 500, "y2": 550}}}},
    "id7": {"Dyad": {"edges": [{"S": 1, "E": 2}]}},
    "id8": {"Dyad": {"edges": [{"S": 1, "M": [{"x": 250, "y": 100}], "E": 2}]}},
    "id9": {
      "Dyad": {
        "edges": [
          {"S": 1, "E": -1},
          {"S": 2, "M": [{"x": 600, "y": 100}], "E": -1},
          {"S": 3, "E": -1}
        ],
        "junctions": [{"x": 450, "y": 100}]
      }
    },
    "id10": {
      "Dyad": {
        "edges": [
          {"S": 1, "M": [{"x": 600, "y": 400}], "E": -1},
          {"S": 2, "E": -1},
          {"S": 3, "E": -1},
          {"S": -1, "M": [{"x": 250, "y": 400}], "E": 4}
        ],
        "junctions": [{"x": 450, "y": 400}]
      }
    }
  }
}
end

analysis SimpleSineRLCTransient
  extends TransientAnalysis(alg = ODEAlg.Auto(), abstol = 10m, reltol = 1m, start = 0, stop = 10)
  model::SinRLC() = SinRLC()
relations
end