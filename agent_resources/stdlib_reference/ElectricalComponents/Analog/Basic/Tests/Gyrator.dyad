"""
MSL validation test: Gyrator.

Recreates `ModelicaTest.Electrical.Analog.TestGyrator` from MSL.
Two constant voltage sources (v1=1 V, v2=1 V) drive a gyrator with
G1=1 S and G2=2 S. Both sides are grounded.

Expected steady-state values (algebraic, constant for all t):
- gyrator.i1 = G2 * v2 =  2 A
- gyrator.i2 = -G1 * v1 = -1 A

MSL reference: tolerance=1e-6, StopTime=1.
"""
test component Gyrator
  "Constant signal for primary voltage source (1 V)"
  const1 = BlockComponents.Sources.Constant(k = 1) {^const1}
  "Constant signal for secondary voltage source (1 V)"
  const2 = BlockComponents.Sources.Constant(k = 1) {^const2}
  "Primary voltage source"
  v1 = ElectricalComponents.Analog.Sources.VoltageSource() {^v1}
  "Secondary voltage source"
  v2 = ElectricalComponents.Analog.Sources.VoltageSource() {^v2}
  "Gyrator: G1=1 S, G2=2 S"
  gyrator = ElectricalComponents.Analog.Basic.Gyrator(G1 = 1, G2 = 2) {^gyrator}
  "Primary ground"
  ground1 = ElectricalComponents.Analog.Basic.Ground() {^ground1}
  "Secondary ground"
  ground2 = ElectricalComponents.Analog.Basic.Ground() {^ground2}
relations
  connect(const1.y, v1.V) {^id8}
  connect(const2.y, v2.V) {^id9}
  connect(v1.p, gyrator.p1) {^id10}
  connect(v1.n, ground1.g) {^id11}
  connect(v2.p, gyrator.p2) {^id12}
  connect(v2.n, gyrator.n2) {^id13}
  connect(v2.n, ground2.g) {^id14}
  connect(v1.n, gyrator.n1) {^id15}
metadata {
