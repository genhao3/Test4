"""
Test circuit for MTransformer with N=2.

Replicates the primary-side circuit from the MSL CompareTransformers example:
  SineVoltage → R1 → Transformer primary → Ground (primary side)
  Transformer secondary → R2 → Load → Ground (secondary side)

With these parameters the MTransformer(N=2) should behave identically
to the MSL Basic.Transformer(L1, L2, M).

Parameters (from MSL CompareTransformers):
  f = 10 Hz, Vpeak = 0.1 V, Vdc = 0.1 V, phase = pi/2
  n = 2 (turns ratio)
  R1 = 0.01 Ω, R2 = 0.0025 Ω, RL = 0.25 Ω
  L1 ≈ 0.16 H, L2 ≈ 0.04 H, M ≈ 0.07958 H
"""
test component MTransformer
  # Sine voltage source (primary side)
  sine = BlockComponents.Sources.Sine(offset = 0.1, amplitude = 0.1, frequency = 10.0, phase = 1.5707963267948966) {^sine}
  source = ElectricalComponents.Analog.Sources.VoltageSource() {^source}
  # Primary winding resistance
  r1 = ElectricalComponents.Analog.Basic.Resistor(R = 0.01) {^r1}
  # The MTransformer with N=2
  transformer = ElectricalComponents.Analog.Basic.MTransformer(N = 2, L = [0.15996, 0.07958, 0.03999]) {^transformer}
  # Secondary winding resistance
  r2 = ElectricalComponents.Analog.Basic.Resistor(R = 0.0025) {^r2}
  # Load resistor
  load = ElectricalComponents.Analog.Basic.Resistor(R = 0.25) {^load}
  # Separate grounds for primary and secondary (galvanic isolation)
  gnd1 = ElectricalComponents.Analog.Basic.Ground() {^gnd1}
  gnd2 = ElectricalComponents.Analog.Basic.Ground() {^gnd2}
relations
  # Drive voltage source with sine
  connect(sine.y, source.V) {^id9}
  # Primary side: source → R1 → transformer winding 1 → ground
  connect(source.p, r1.p) {^id10}
  connect(r1.n, transformer.p[1]) {^id11}
  connect(transformer.n[1], gnd1.g, source.n) {^id12}
  # Secondary side: transformer winding 2 → R2 → load → ground
  connect(transformer.p[2], r2.p) {^id13}
  connect(r2.n, load.p) {^id14}
  connect(load.n, gnd2.g, transformer.n[2]) {^id15}
metadata {
