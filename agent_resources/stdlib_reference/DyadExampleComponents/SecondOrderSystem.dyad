component SecondOrderSystem
  xdd = RealInput() {^xdd}
  integrator1 = BlockComponents.Continuous.Integrator() {^integrator1}
  integrator2 = BlockComponents.Continuous.Integrator() {^integrator2}
  gain1 = BlockComponents.Math.Gain(k = k1) {^gain1}
  gain2 = BlockComponents.Math.Gain(k = k2) {^gain2}
  gain3 = BlockComponents.Math.Gain(k = k3) {^gain3}
  sum = BlockComponents.Math.Add3() {^sum}
  parameter k1::Real
  parameter k2::Real
  parameter k3::Real
relations
  connect(integrator1.u, gain1.u, xdd) {^id8}
  connect(gain3.u, integrator2.y) {^id9}
  connect(sum.u3, gain1.y) {^id10}
  connect(sum.u2, gain2.y) {^id11}
  connect(sum.u1, gain3.y) {^id12}
  connect(integrator1.y, integrator2.u) {^id13}
  connect(integrator1.y, gain2.u) {^id14}
