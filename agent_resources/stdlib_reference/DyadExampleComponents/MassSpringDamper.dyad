component MassSpringDamper
  mass = TranslationalComponents.Components.Mass(m = m, L = 0.0, g = g, theta = theta) {^mass}
  spring_damper = TranslationalComponents.Components.SpringDamper(d = d, c = c, s_rel0 = missing) {^spring_damper}
  flange_m = Flange() {^flange_m}
  flange_sd = Flange() {^flange_sd}
  "Component mass"
  parameter m::Dyad.Mass
  "Stiffness of the spring"
  parameter c::TranslationalSpringConstant
  "Damping coefficient"
  parameter d::DampingCoefficient
  "Gravity"
  parameter g::Acceleration
  "Angle of motion with +X axis"
  parameter theta::Angle = 0
relations
  guess spring_damper.s_rel0 = 0
  connect(flange_m, mass.flange_b, spring_damper.flange_a) {^id5}
  connect(flange_sd, spring_damper.flange_b) {^id6}
