component DCMotor
  p = Pin() {^p}
  n = Pin() {^n}
  shaft = Spline() {^shaft}
  housing = Spline() {^housing}
  R1 = ElectricalComponents.Analog.Basic.Resistor(R = R) {^R1}
  L1 = ElectricalComponents.Analog.Basic.Inductor(L = L) {^L1}
  emf = ElectricalComponents.Analog.Basic.RotationalEMF(k = k) {^emf}
  inertia = RotationalComponents.Components.Inertia(J = J) {^inertia}
  friction = RotationalComponents.Components.Damper(d = f) {^friction}
  "Armature resistance"
  parameter R::Resistance = 0.5
  "Armature inductance"
  parameter L::Inductance = 4.5e-3
  "Motor constant"
  parameter k::ElectricalTorqueConstant = 0.5
  "Motor inertia"
  parameter J::Inertia = 0.02
  "Motor friction factor"
  parameter f::RotationalDampingConstant = 0.01
relations
  initial inertia.phi = 0
  connect(p, R1.p) {^id10}
  connect(R1.n, L1.p) {^id11}
  connect(L1.n, emf.p) {^id12}
  connect(emf.n, n) {^id13}
  connect(emf.rotor, inertia.spline_a, friction.spline_a) {^id14}
  connect(friction.spline_b, emf.housing, housing) {^id15}
  connect(inertia.spline_b, shaft) {^id16}
