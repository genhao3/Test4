test component TestDCMotorLoadControlled
  motor = DCMotor() {^motor}
  ground = ElectricalComponents.Analog.Basic.Ground() {^ground}
  source = ElectricalComponents.Analog.Sources.VoltageSource() {^source}
  fixed = RotationalComponents.Components.Fixed() {^fixed}
  load = RotationalComponents.Sources.TorqueSource() {^load}
  load_source = BlockComponents.Sources.Step(height = tau_load, start_time = load_step_start_time) {^load_source}
  speed_reference = BlockComponents.Sources.Constant(k = w_motor) {^speed_reference}
  controller = BlockComponents.Continuous.LimPID(k = k, Ti = Ti, Td = Td, Nd = Nd, y_max = 5, y_min = -5) {^controller}
  signal_ff = BlockComponents.Sources.Constant(k = 0) {^signal_ff}
  speed_sensor = RotationalComponents.Sensors.VelocitySensor() {^speed_sensor}
  "Motor desired speed"
  parameter w_motor::AngularVelocity = 1
  "Amplitude of load torque step"
  parameter tau_load::Torque = -0.3
  "Load step start time"
  parameter load_step_start_time::Time = 2
  "Controller gain"
  parameter k::Real = 0.5
  "Controller time constant of the integrator block"
  parameter Ti::Time = 0.1
  "Controller Time constant of the derivative block"
  parameter Td::Time = 1e5
  "Maximum derivative gain"
  parameter Nd::Real = 10
relations
  initial motor.L1.i = 0
  initial motor.inertia.w = 0
  u: analysis_point(controller.y, source.V)
  y: analysis_point(speed_sensor.w, controller.u_m)
  r: analysis_point(speed_reference.y, controller.u_s)
  connect(load_source.y, load.tau) {^id11}
  connect(source.p, motor.p) {^id12}
  connect(ground.g, source.n, motor.n) {^id13}
  connect(motor.shaft, load.spline) {^id14}
  connect(motor.housing, load.support, fixed.spline) {^id15}
  connect(speed_reference.y, controller.u_s) {^id16}
  connect(speed_sensor.w, controller.u_m) {^id17}
  connect(controller.y, source.V) {^id18}
  connect(speed_sensor.spline, motor.shaft) {^id19}
  connect(controller.u_ff, signal_ff.y) {^id20}
