"""
PID controller with limited output, anti-windup, and an external derivative input.

A variant of `LimPID` where the internal filtered derivative block is removed entirely.
Instead, the derivative contribution is supplied externally via the `u_d` input, which
feeds directly into the PID summation with no internal filtering or differentiation.
The derivative passed to the derivative input should be that of the control error
`u_s - u_m`, potentially applying set-point weighting. To use a derivative of the
measurement signal only, the gain should be -1, i.e., pass the derivative of `-u_m`.

Use this component when the derivative signal is already available from the plant
(e.g., a velocity sensor, a model state, or an observer output) and internal
numerical differentiation is unnecessary or undesirable.

The output is:

```math
y = k \left[e_p + \dfrac{1}{T_is}\left(e + \dfrac{y_{sat} - y}{N_iT_i}\right) + u_d \right] + k_{ff}u_{ff}
```

where `e_p = w_p \cdot u_s - u_m`, `e = u_s - u_m`, and `u_d` is the externally
supplied derivative signal passed through without modification.
"""
component LimPIDExternalDerivative
  extends BlockComponents.Interfaces.SingleVariableController
  "Feed-forward input"
  u_ff = RealInput() {^u_ff}
  "External derivative input"
  u_d = RealInput() {^u_d}
  add_p = BlockComponents.Math.Add(k1 = wp, k2 = -1) {^add_p}
  add_i = BlockComponents.Math.Add3(k2 = -1) {^add_i}
  proportional = BlockComponents.Math.Gain(k = 1) {^proportional}
  integrator = Integrator(k = 1 / Ti, x0 = xi0) {^integrator}
  add_pid = BlockComponents.Math.Add3() {^add_pid}
  gain_pid = BlockComponents.Math.Gain(k = k) {^gain_pid}
  add_ff = BlockComponents.Math.Add(k2 = k_ff) {^add_ff}
  limiter = BlockComponents.Nonlinear.Limiter(y_max = y_max, y_min = y_min) {^limiter}
  add_sat = BlockComponents.Math.Add(k1 = 1, k2 = -1) {^add_sat}
  gain_track = BlockComponents.Math.Gain(k = 1 / (k * Ni)) {^gain_track}
  variable control_error::Real
  "Gain of controller"
  parameter k::Real = 1
  "Time constant of the integrator block"
  parameter Ti::Time = 0.5
  "Maximum output"
  parameter y_max::Real = 1e300
  "Minimum output"
  parameter y_min::Real = -y_max
  "Set-point weight for proportional block"
  parameter wp::Real = 1
  "`Ni*Ti` is time constant of anti-windup compensation"
  parameter Ni::Real = 0.9
  "Gain of the feed-forward input"
  parameter k_ff::Real = 1
  "Initial guess value for integrator output"
  parameter xi0::Real = 0
relations
  control_error = u_s - u_m
  connect(add_p.y, proportional.u) {^id13}
  connect(add_i.y, integrator.u) {^id14}
  connect(proportional.y, add_pid.u1) {^id15}
  connect(integrator.y, add_pid.u3) {^id16}
  connect(add_pid.y, gain_pid.u) {^id17}
  connect(gain_pid.y, add_ff.u1) {^id18}
  connect(add_ff.y, limiter.u) {^id19}
  connect(limiter.y, add_sat.u1) {^id20}
  connect(add_sat.y, gain_track.u) {^id21}
  connect(gain_track.y, add_i.u3) {^id22}
  connect(add_sat.u2, add_ff.y) {^id23}
  connect(limiter.y, y) {^id24}
  connect(add_ff.u2, u_ff) {^id25}
  connect(add_pid.u2, u_d) {^id26}
  connect(add_p.u1, u_s) {^id27}
  connect(add_i.u1, u_s) {^id28}
  connect(add_p.u2, u_m) {^id29}
  connect(add_i.u2, u_m) {^id30}
metadata {
