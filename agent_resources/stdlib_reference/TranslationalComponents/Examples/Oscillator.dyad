    "icons": {"default": "dyad://TranslationalComponents/Example.svg"},
    "tests": {
      "case1": {
        "stop": 1,
        "atol": {
          "damper1.s_rel": 0.001,
          "damper1.v_rel": 0.001,
          "mass1.s": 0.001,
          "mass1.v": 0.01
        },
        "expect": {
          "final": {
            "damper1.s_rel": 1.00086,
            "damper1.v_rel": 0.05020,
            "mass1.s": -0.50433,
            "mass1.v": -0.25276
          },
          "signals": ["damper1.s_rel", "damper1.v_rel", "mass1.s", "mass1.v"]
        }
      }
    }
  },
